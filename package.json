{
  "name": "titip-protocol",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --filter @titip/web dev",
    "build": "pnpm --filter @titip/web build",
    "vercel-build": "npm --prefix packages/db install @prisma/client@6.19.3 && npm --prefix packages/db run db:generate && npm --prefix apps/web run build",
    "setup": "docker compose up -d && cd packages/db && pnpm db:generate && pnpm db:migrate && cd ../.. && echo Setup complete!",
    "demo:deploy": "npx dotenv-cli -e .env.local -- npx tsx scripts/deploy-contract.ts",
    "demo:sac": "npx dotenv-cli -e .env.local -- npx tsx scripts/deploy-usdc-sac.ts",
    "demo:fund": "npx dotenv-cli -e .env.local -- npx tsx scripts/fund-testnet-accounts.ts",
    "demo:usdc": "npx dotenv-cli -e .env.local -- npx tsx scripts/setup-demo-usdc.ts",
    "demo:simulate": "npx dotenv-cli -e .env.local -- npx tsx scripts/simulate-lifecycle.ts",
    "demo:confirm": "npx dotenv-cli -e .env.local -- npx tsx scripts/demo-oracle-confirm.ts",
    "demo:verify": "npx dotenv-cli -e .env.local -- npx tsx scripts/verify-onchain-lifecycle.ts",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@stellar/stellar-sdk": "^16.0.1",
    "dotenv-cli": "^11.0.0",
    "tsx": "^4.23.1"
  },
  "dependencies": {
    "@prisma/client": "6.19.3"
  }
}
